CreateToggle("自动刷活动", function(state)
    _G.test = state
    if _G.test then
        if not game.ReplicatedStorage:FindFirstChild("mrbackupfolder") then
            local folder = Instance.new("Folder",game.ReplicatedStorage)
            folder.Name = "mrbackupfolder"
        end
        local plr = game.Players.LocalPlayer
        for i,v in pairs(workspace:GetChildren()) do
            if v.ClassName == "Model" and not string.find(v.Name,plr.Name) and not string.find(v.Name,plr.DisplayName) and not string.find(v.Name,"Gift") and v.Name ~= "" or
            v.ClassName == "Folder" and not string.find(v.Name,plr.Name) and not string.find(v.Name,plr.DisplayName) and not string.find(v.Name,"Gift") and v.Name ~= "" or v:IsA("MeshPart") then
                v.Parent = game.ReplicatedStorage:FindFirstChild("mrbackupfolder")
            end
        end
        task.wait()
    else
        if getfenv().tween then
            getfenv().tween:Cancel()
        end
        if game.ReplicatedStorage:FindFirstChild("mrbackupfolder") then
            for i,v in pairs(game.ReplicatedStorage:FindFirstChild("mrbackupfolder"):GetChildren()) do
                v.Parent = workspace
                task.wait()
            end
        end
        task.wait()
    end
    
    while _G.test do
        task.wait()
        if not _G.ooga then
            local new = Instance.new("Part",workspace)
            new.Anchored = true
            new.Size = Vector3.new(10000,10,10000)
            _G.ooga = new
        end
        local plr = game.Players.LocalPlayer
        local chr = plr.Character
        if not chr or not chr:FindFirstChild("Humanoid") then continue end
        local seat = chr.Humanoid.SeatPart
        if not seat then continue end
        
        getfenv().car = seat.Parent
        local car = getfenv().car
        car.PrimaryPart = car.Body:FindFirstChild("#Weight")
        local locations 
        local maxdistance = math.huge
        
        for i,v in pairs(workspace:GetChildren()) do
            if v.Name == "" and v:FindFirstChild("Highlight") then
                local dist = (chr.PrimaryPart.Position - v.WorldPivot.Position).magnitude
                if dist < maxdistance then
                    maxdistance = dist
                    locations = v
                end
            end
        end
        
        if locations and getfenv().method == "Tweening" then
            repeat task.wait()
                local speed = getfenv().speed or 230
                getfenv().car = car
                if getfenv().cancelman then
                    speed = 50
                end
                local pos = locations.WorldPivot + Vector3.new(0,5,0)
                local dist = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - pos.Position).magnitude
                local TweenService = game:GetService("TweenService")
                local TweenInfoToUse = TweenInfo.new(dist/speed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0)
                
                local TweenValue = Instance.new("CFrameValue")
                TweenValue.Value = getfenv().car:GetPrimaryPartCFrame()
                             
                TweenValue.Changed:Connect(function()
                    local test = TweenValue.Value.Position
                    if plr:DistanceFromCharacter(pos.Position) > 100 then
                        _G.ooga.Position = test - Vector3.new(0,14,0)
                        getfenv().car:PivotTo(CFrame.new(_G.ooga.Position+Vector3.new(0,7,0), pos.Position))
                        local velo = getfenv().car.PrimaryPart.CFrame.LookVector * speed
                        getfenv().car.PrimaryPart.AssemblyLinearVelocity = velo
                    elseif plr:DistanceFromCharacter(pos.Position) < 100 and plr:DistanceFromCharacter(pos.Position) > 10 then
                        if not getfenv().cancelman then
                            getfenv().cancelman = true
                            if getfenv().tween then getfenv().tween:Cancel() end
                        end
                        local velo = getfenv().car.PrimaryPart.CFrame.LookVector * 20
                        _G.ooga.Position = test - Vector3.new(0,8,0)
                        getfenv().car:PivotTo(CFrame.new(_G.ooga.Position+Vector3.new(0,7,0), Vector3.new(pos.X, getfenv().car.PrimaryPart.CFrame.Y, pos.Z)))
                        getfenv().car.PrimaryPart.AssemblyLinearVelocity = velo
                    elseif plr:DistanceFromCharacter(pos.Position) < 5 then
                        local lookat = getfenv().car.PrimaryPart.CFrame * CFrame.new(0,0,-10000)
                        getfenv().car:PivotTo(CFrame.new(Vector3.new(pos.X, _G.ooga.CFrame.Y+7, pos.Z), lookat.Position))
                        car.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
                    end
                end)
                             
                getfenv().tween = TweenService:Create(TweenValue, TweenInfoToUse, {Value=pos})
                getfenv().tween:Play()
                repeat task.wait()
                until getfenv().tween.PlaybackState == Enum.PlaybackState.Cancelled or getfenv().tween.PlaybackState == Enum.PlaybackState.Completed or getfenv().tween.PlaybackState == Enum.PlaybackState.Paused or not _G.test
            until not locations:FindFirstChild("Highlight") or not _G.test 
            getfenv().cancelman = nil
            
        elseif locations and getfenv().method ~= "Tweening" then
            _G.ooga.Position = Vector3.new(car.PrimaryPart.CFrame.X, locations.WorldPivot.Y-3, car.PrimaryPart.CFrame.Z)
            car:PivotTo(CFrame.new(car.PrimaryPart.CFrame.X, _G.ooga.CFrame.Y+7, car.PrimaryPart.CFrame.Z))
            
            repeat task.wait()
                local movespeed = getfenv().speed or 230
                car.PrimaryPart.Velocity = car.PrimaryPart.CFrame.LookVector * movespeed
                car:PivotTo(CFrame.new(car.PrimaryPart.Position, locations.WorldPivot.Position))
                _G.ooga.Position = Vector3.new(car.PrimaryPart.CFrame.X, locations.WorldPivot.Y-3, car.PrimaryPart.CFrame.Z)
            until game.Players.LocalPlayer:DistanceFromCharacter(locations.WorldPivot.Position) < 100 or _G.test == false 
            
            repeat task.wait()
                local movespeed = getfenv().speed or 230
                car.PrimaryPart.Velocity = car.PrimaryPart.CFrame.LookVector * 100
                local lookat = getfenv().car.PrimaryPart.CFrame * CFrame.new(0,0,-10000)
                if plr:DistanceFromCharacter(Vector3.new(locations.WorldPivot.X, car.PrimaryPart.CFrame.Y, locations.WorldPivot.Z)) > 100 then
                    car:PivotTo(CFrame.new(car.PrimaryPart.Position, locations.WorldPivot.Position))
                else
                    car:PivotTo(CFrame.new(car.PrimaryPart.Position, lookat.Position))
                end
                _G.ooga.Position = Vector3.new(car.PrimaryPart.CFrame.X, locations.WorldPivot.Y-3, car.PrimaryPart.CFrame.Z)
            until game.Players.LocalPlayer:DistanceFromCharacter(Vector3.new(locations.WorldPivot.X, car.PrimaryPart.CFrame.Y, locations.WorldPivot.Z)) < 5 or _G.test == false
            
            repeat task.wait() 
                local lookat = getfenv().car.PrimaryPart.CFrame * CFrame.new(0,0,-10000)
                getfenv().car:PivotTo(CFrame.new(Vector3.new(locations.WorldPivot.X, _G.ooga.CFrame.Y+7, locations.WorldPivot.Z), lookat.Position))
                car.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
                _G.ooga.Position = Vector3.new(car.PrimaryPart.CFrame.X, locations.WorldPivot.Y-3, car.PrimaryPart.CFrame.Z)
            until not locations:FindFirstChild("Highlight") or not _G.test 
            
        elseif not locations and workspace:FindFirstChild("GiftPickup") then
            repeat task.wait()
                car.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
                car:PivotTo(CFrame.new(workspace.GiftPickup.WorldPivot.Position) + Vector3.new(0,5,0))
            until reachedMax(car) or not _G.test
        end
    end
end)
