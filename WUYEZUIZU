local function reachedMax(value)
    local test = 0
    for i,v in pairs(value:GetDescendants()) do
        if v:IsA("Seat") then
            test = test + 1
        end
    end
    test = test * 5
    if value:FindFirstChild("Gifts") and #value.Gifts:GetChildren() == test then
        test = true
    else
        test = false 
    end
    return test
end

