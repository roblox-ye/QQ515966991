-- ====== 重新设计的高级极简物理涟漪特效 (不使用图像资产) ======
function Ripple(obj)
    spawn(function()
        if obj.ClipsDescendants ~= true then
            obj.ClipsDescendants = true
        end

        -- 微物理反馈：文字下陷/被推动感 (微上移)
        local TextLabel = obj:FindFirstChildWhichIsA("TextLabel")
        if TextLabel then
            services.TweenService:Create(TextLabel, TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(TextLabel.Position.X.Scale, TextLabel.Position.X.Offset, TextLabel.Position.Y.Scale, TextLabel.Position.Y.Offset - 2)}):Play()
        end

        local EffectCircle = Instance.new("Frame") -- 纯色 Frame
        local EffectCircleC = Instance.new("UICorner") -- 圆角
        EffectCircleC.CornerRadius = UDim.new(1, 0) -- 完美圆形
        EffectCircleC.Parent = EffectCircle

        EffectCircle.Name = "RippleEffect"
        EffectCircle.Parent = obj
        EffectCircle.BackgroundColor3 = zyColor -- 使用高亮色作为涟漪
        EffectCircle.BackgroundTransparency = 0.5 -- 半透
        EffectCircle.ZIndex = 8
        EffectCircle.Size = UDim2.new(0, 0, 0, 0) -- 初始大小 0

        -- 将圆心定位在点击位置
        local mouseX, mouseY = mouse.X, mouse.Y
        EffectCircle.Position = UDim2.new(0, mouseX - EffectCircle.AbsolutePosition.X, 0, mouseY - EffectCircle.AbsolutePosition.Y)

        -- 创建大小和透明度 Tween
        local tInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) -- Quart 曲线模拟物理感
        local sizeT = services.TweenService:Create(EffectCircle, tInfo, {Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0)}) -- 缩放并重新对齐
        local transT = services.TweenService:Create(EffectCircle, tInfo, {BackgroundTransparency = 1}) -- 淡出

        sizeT:Play() -- 播放大小 Tween

        spawn(function()
            transT:Play() -- 同时播放透明度 Tween
            wait(0.4)
            -- 特效结束，文字恢复原位
            if TextLabel then
                services.TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(TextLabel.Position.X.Scale, TextLabel.Position.X.Offset, TextLabel.Position.Y.Scale, TextLabel.Position.Y.Offset + 2)}):Play()
            end
            EffectCircle:Destroy() -- 销毁
        end)
    end)
end
