            table.insert(_G.activeUITweens, closeTween)
            
            closeTween.Completed:Once(function() 
                CloudMain.Visible = false 
                if mainStroke then mainStroke.Enabled = true end
                if dropShadow then dropShadow.Visible = true end
            end)
            
            closeTween:Play()
        end
    end

