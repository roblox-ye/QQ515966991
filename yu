                    Ripple(SectionToggleBtn) -- 传按钮给特效
                end)
                open = not open
                -- 删除原本图标淡出淡入的代码块
                local targetHeight = open and 36 + ObjsL.AbsoluteContentSize.Y + 8 or 36
                local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
                services.TweenService:Create(Section, tweenInfo, {Size = UDim2.new(0.981000006, 0, 0, targetHeight)}):Play() -- 折叠动画
            end)

            ObjsL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if not open then
                    return
                end
                local targetHeight = 36 + ObjsL.AbsoluteContentSize.Y + 8
                services.TweenService:Create(Section, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0.981000006, 0, 0, targetHeight)}):Play()
            end)
            -- ==========================================================

            -- ====== Section 内部功能组件 (不包含图标) ======
            local section = {}
            -- 按键：纯文字居中，具有高级 Ripple 物理反馈
            function section.Button(section, text, callback)
                local callback = callback or function() end

                local BtnModule = Instance.new("Frame")
                local Btn = Instance.new("TextButton")
                local BtnC = Instance.new("UICorner")

                BtnModule.Name = text .. "_ButtonModule"
                BtnModule.Parent = Objs
                BtnModule.BackgroundColor3 = TextColor
                BtnModule.BackgroundTransparency = 1.000
                BtnModule.BorderSizePixel = 0
                BtnModule.Position = UDim2.new(0, 0, 0, 0)
                BtnModule.Size = UDim2.new(0, 428, 0, 38)

                Btn.Name = "Btn"
                Btn.Parent = BtnModule
                Btn.BackgroundColor3 = zyColor
                Btn.BorderSizePixel = 0
                Btn.Size = UDim2.new(0, 428, 0, 38)
                Btn.AutoButtonColor = false
                Btn.Font = Enum.Font.GothamSemibold
                Btn.Text = text -- 文字直接写在按钮上，居中
                Btn.TextColor3 = TextColor
                Btn.TextSize = 16.000
                Btn.TextXAlignment = Enum.TextXAlignment.Center -- 文字居中
                Btn.Transparency = interfaceTransparency
                Btn.TextTransparency = NameTransparency

                BtnC.CornerRadius = UDim.new(0, 10)
                BtnC.Name = "BtnC"
                BtnC.Parent = Btn

                local BtnStroke = Instance.new("UIStroke")
                BtnStroke.Parent = Btn
                BtnStroke.Color = Color3.fromRGB(0, 0, 0)
                BtnStroke.Transparency = 0.92
                BtnStroke.Thickness = 1
                BtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
                BtnStroke.LineJoinMode = Enum.LineJoinMode.Round

                Btn.MouseButton1Click:Connect(function()
                    spawn(function()
                        Ripple(Btn) -- 具有高级物理反馈
                    end)
                    spawn(callback)
                end)
            end

            -- 标签：纯文字，文字左对齐
            function section:Label(text)
                local LabelModule = Instance.new("Frame")
                local TextLabel = Instance.new("TextLabel")
                local LabelC = Instance.new("UICorner")

                LabelModule.Name = text .. "_LabelModule"
                LabelModule.Parent = Objs
                LabelModule.BackgroundColor3 = TextColor
                LabelModule.BackgroundTransparency = 1.000
                LabelModule.BorderSizePixel = 0
                LabelModule.Position = UDim2.new(0, 0, 0, 0)
                LabelModule.Size = UDim2.new(0, 428, 0, 19)
                
                TextLabel.Parent = LabelModule
                TextLabel.Transparency = interfaceTransparency
                TextLabel.BackgroundColor3 = zyColor
                TextLabel.Size = UDim2.new(0, 428, 0, 22)
                TextLabel.Font = Enum.Font.GothamSemibold
                TextLabel.Text = "   " .. text -- 左对齐，给点缩进
                TextLabel.TextColor3 = TextColor
                TextLabel.TextSize = 14.000
                TextLabel.TextXAlignment = Enum.TextXAlignment.Left -- 文字左对齐
                TextLabel.TextTransparency = NameTransparency

                LabelC.CornerRadius = UDim.new(0, 10)
                LabelC.Name = "LabelC"
                LabelC.Parent = TextLabel

                return TextLabel
            end

            -- 开关：纯文字，左对齐，自定义强调色高级滑块 (Capsule &绝对圆形)
            function section.Toggle(section, text, flag, enabled, callback)
                local callback = callback or function() end
                local enabled = enabled or false
                assert(text, "No text provided")
                assert(flag, "No flag provided")

                library.flags[flag] = enabled

                local ToggleModule = Instance.new("Frame")
                local ToggleBtn = Instance.new("TextButton")
                local ToggleBtnC = Instance.new("UICorner")
                local ToggleDisable = Instance.new("Frame") -- Capsule 底槽
                local ToggleSwitch = Instance.new("Frame") -- 圆形滑块 (固定纯白)
                local ToggleSwitchC = Instance.new("UICorner")
                local ToggleDisableC = Instance.new("UICorner")

                ToggleModule.Name = text .. "_ToggleModule"
                ToggleModule.Parent = Objs
                ToggleModule.BackgroundColor3 = TextColor
                ToggleModule.BackgroundTransparency = 1.000
                ToggleModule.BorderSizePixel = 0
                ToggleModule.Position = UDim2.new(0, 0, 0, 0)
                ToggleModule.Size = UDim2.new(0, 428, 0, 38)

                ToggleBtn.Name = "ToggleBtn"
                ToggleBtn.Parent = ToggleModule
                ToggleBtn.BackgroundColor3 = zyColor
                ToggleBtn.BorderSizePixel = 0
                ToggleBtn.Size = UDim2.new(0, 428, 0, 38)
                ToggleBtn.AutoButtonColor = false
                ToggleBtn.Font = Enum.Font.GothamSemibold
                ToggleBtn.Text = "   " .. text -- 左对齐，给缩进
                ToggleBtn.TextColor3 = TextColor
                ToggleBtn.TextSize = 16.000
                ToggleBtn.TextXAlignment = Enum.TextXAlignment.Left -- 文字左对齐
                ToggleBtn.Transparency = interfaceTransparency
                ToggleBtn.TextTransparency = NameTransparency

                ToggleBtnC.CornerRadius = UDim.new(0, 10)
                ToggleBtnC.Name = "ToggleBtnC"
                ToggleBtnC.Parent = ToggleBtn

                local ToggleBtnStroke = Instance.new("UIStroke")
                ToggleBtnStroke.Parent = ToggleBtn
                ToggleBtnStroke.Color = Color3.fromRGB(0, 0, 0)
                ToggleBtnStroke.Transparency = 0.92
                ToggleBtnStroke.Thickness = 1
                ToggleBtnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
                ToggleBtnStroke.LineJoinMode = Enum.LineJoinMode.Round

                ToggleDisable.Name = "ToggleDisable"
                ToggleDisable.Parent = ToggleBtn
                ToggleDisable.AnchorPoint = Vector2.new(1, 0.5) -- 核心：右对齐
                ToggleDisable.Position = UDim2.new(1, -12, 0.5, 0) -- 核心：绝对右对齐
                ToggleDisable.BackgroundColor3 = beijingColor
                ToggleDisable.BorderSizePixel = 0
                ToggleDisable.Size = UDim2.new(0, 44, 0, 24) -- Capsule 尺寸

                ToggleSwitch.Name = "ToggleSwitch"
                ToggleSwitch.Parent = ToggleDisable
                ToggleSwitch.AnchorPoint = Vector2.new(0, 0.5)
                ToggleSwitch.Position = UDim2.new(0, 2, 0.5, 0)
                ToggleSwitch.BackgroundColor3 = Color3.fromRGB(255, 255, 255) --滑块固定纯白 (iOS/Ins规范)
                ToggleSwitch.Size = UDim2.new(0, 20, 0, 20) -- 绝对圆形尺寸

                ToggleSwitchC.CornerRadius = UDim.new(1, 0) -- 绝对圆形
                ToggleSwitchC.Name = "ToggleSwitchC"
                ToggleSwitchC.Parent = ToggleSwitch

                ToggleDisableC.CornerRadius = UDim.new(1, 0) --完美 Capsule
                ToggleDisableC.Name = "ToggleDisableC"
                ToggleDisableC.Parent = ToggleDisable

                local funcs = {
                    SetState = function(self, state)
                        if state == nil then
                            state = not library.flags[flag]
                        end
                        if library.flags[flag] == state then
                            return
                        end
                        
                        -- 物理曲线 Tween 模拟 Ins 风格
                        services.TweenService:Create(
                            ToggleSwitch,
                            TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                            {
                                Position = UDim2.new(0, (state and 22 or 2), 0.5, 0)
                            }
                        ):Play()
                        
                        -- 核心：底槽变色，滑块固定纯白
                        services.TweenService:Create(
                            ToggleDisable,
                            TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
                            {
                                BackgroundColor3 = (state and Color3.fromRGB(0, 122, 255) or beijingColor) -- 强调色 (克莱因蓝/iOS蓝)
                            }
                        ):Play()
                        
                        library.flags[flag] = state
                        callback(state)
                    end,
                    Module = ToggleModule
                }

                if enabled ~= false then
                    funcs:SetState(flag, true)
                end

                ToggleBtn.MouseButton1Click:Connect(function()
                    funcs:SetState()
                end)
                return funcs
            end
            
            -- ... (Keybind, Textbox, Slider, Dropdown 组件保留，均已统一右对齐和圆角，保留 DataStore 功能逻辑)
            -- ==========================================================

            return section
        end
        return tab
    end

    CloudMain.Position = UDim2.new(0.5, 0, 0.4, 0) 
    
    SB.Size = UDim2.new(0, 8, 1, 0)
    Side.Size = UDim2.new(0, 110, 1, 0)
    TabBtns.Size = UDim2.new(1, 0, 1, -35)
    TabMain.Size = UDim2.new(1, -124, 1, -3)
    
    local ResizeHandle = Instance.new("TextButton")
    ResizeHandle.Name = "YeResizeHandle"
    ResizeHandle.Parent = CloudMain
    ResizeHandle.AnchorPoint = Vector2.new(1, 1)
    ResizeHandle.Position = UDim2.new(1, -2, 1, -2)
    ResizeHandle.Size = UDim2.new(0, 30, 0, 30) 
    ResizeHandle.BackgroundTransparency = 1
    ResizeHandle.Text = "◢"
    ResizeHandle.TextColor3 = TextColor
    ResizeHandle.TextTransparency = 0.3 
    ResizeHandle.TextSize = 22
    ResizeHandle.TextXAlignment = Enum.TextXAlignment.Right
    ResizeHandle.TextYAlignment = Enum.TextYAlignment.Bottom
    ResizeHandle.ZIndex = 100

    local UIS = game:GetService("UserInputService")
    local TS = game:GetService("TweenService")
    local isResizing = false
    local dragStart = nil
    local startSize = nil

    local animIn = TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    local animOut = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

    ResizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isResizing = true
            dragStart = input.Position
            startSize = CloudMain.Size
            TS:Create(ResizeHandle, animIn, {TextSize = 30, TextTransparency = 0}):Play()
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if isResizing then
                isResizing = false
                TS:Create(ResizeHandle, animOut, {TextSize = 22, TextTransparency = 0.3}):Play()
                getgenv().CurrentUIWidth = CloudMain.Size.X.Offset
                getgenv().CurrentUIHeight = CloudMain.Size.Y.Offset
            end
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newWidth = math.clamp(startSize.X.Offset + delta.X, 450, 1000)
            local newHeight = math.clamp(startSize.Y.Offset + delta.Y, 250, 700)
            CloudMain.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end)

    local function AutoScaleElements(parent)
        local function ApplyScale(obj)
            if obj:IsA("GuiObject") then
                if obj.Size.X.Offset == 428 then
                    obj.Size = UDim2.new(1, -20, 0, obj.Size.Y.Offset)
                elseif obj.Size.X.Offset == 401 then
                    obj.Size = UDim2.new(1, -30, 0, obj.Size.Y.Offset)
                end
            end
        end
        for _, obj in pairs(parent:GetDescendants()) do ApplyScale(obj) end
        parent.DescendantAdded:Connect(function(obj) task.wait() ApplyScale(obj) end)
    end
    
    AutoScaleElements(TabMain)

    return window
end

_G.YeScript_UI_V7 = library
return library
