-- ====== 核心：纯文字推拉物理滑动切换，不使用可见性 Visible，解决卡顿 ======
function switchTab(new) -- new = { TextLabel, TabFrame }
    if switchingTabs then
        return
    end
    local old = library.currentTab
    
    if old == nil then
        -- 首次打开，直接从下往上滑入
        new[2].Position = UDim2.new(0, 0, 1.2, 0)
        services.TweenService:Create(new[2], TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
        
        library.currentTab = new
        services.TweenService:Create(new[1], TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {TextTransparency = 0}):Play() -- 文字淡入
        services.TweenService:Create(new[1].Parent, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 0.9}):Play() -- 按钮亮起
        return
    end

    if old[1] == new[1] then
        return
    end
    
    switchingTabs = true
    library.currentTab = new

    -- 按钮颜色变换
    services.TweenService:Create(old[1], TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {TextTransparency = 0.2}):Play() -- 文字淡出
    services.TweenService:Create(new[1], TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {TextTransparency = 0}):Play() -- 文字淡入
    services.TweenService:Create(old[1].Parent, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 1}):Play() -- 按钮恢复
    services.TweenService:Create(new[1].Parent, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 0.9}):Play() -- 按钮亮起

    -- 核心：纯物理滑动，不再使用 Visible 隐藏/显示，彻底解决卡顿
    -- 旧标签页向上滑出
    services.TweenService:Create(old[2], TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, -1.2, 0)}):Play()
    
    -- 新标签页重置到下方，然后向上滑入
    new[2].Position = UDim2.new(0, 0, 1.2, 0)
    services.TweenService:Create(new[2], TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()

    task.wait(0.35)
    switchingTabs = false
end
